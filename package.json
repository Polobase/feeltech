{
  "name": "feeltech",
  "version": "0.1.0",
  "description": "Comprehensive TypeScript library for FeelTech / FeelElec FY-series arbitrary waveform generators (FY2300, FY6300, FY6600, FY6800, FY6900, FY8300). Works in Node.js (serialport) and browsers (Web Serial API).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/transports/node.d.ts",
      "import": "./dist/transports/node.js"
    },
    "./web": {
      "types": "./dist/transports/web.d.ts",
      "import": "./dist/transports/web.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "docs/serial_protocol.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "example:list": "node --import tsx/esm examples/node-list-ports.ts",
    "example:basic": "node --import tsx/esm examples/node-basic.ts",
    "example:scope": "node --import tsx/esm examples/node-info.ts"
  },
  "keywords": [
    "feeltech",
    "feelelec",
    "fy2300",
    "fy6300",
    "fy6600",
    "fy6800",
    "fy6900",
    "fy8300",
    "signal-generator",
    "function-generator",
    "waveform-generator",
    "arbitrary-waveform",
    "dds",
    "serial",
    "web-serial",
    "serialport",
    "typescript"
  ],
  "author": "Manuel Haller Polo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "browser": {
    "serialport": false,
    "./dist/transports/node.js": false
  },
  "peerDependencies": {
    "serialport": "^12.0.0 || ^13.0.0"
  },
  "peerDependenciesMeta": {
    "serialport": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/w3c-web-serial": "^1.0.6",
    "serialport": "^13.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@serialport/bindings-cpp"]
  }
}
